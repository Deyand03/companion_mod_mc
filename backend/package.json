{
  "name": "companion-backend",
  "version": "0.1.0",
  "description": "AI Backend for Minecraft Companion Mod",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "ws": "^8.18.0",
    "drizzle-orm": "^0.33.0",
    "better-sqlite3": "^11.7.0",
    "zod": "^3.23.0",
    "uuid": "^10.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@types/ws": "^8.5.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "drizzle-kit": "^0.24.0"
  }
}
